{
  "expo": {
    "name": "Archivum",
    "slug": "archivum",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "archivum",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.archivum.app",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.archivum.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Archivum necesita acceso a tu galería para subir documentos.",
          "cameraPermission": "Archivum necesita acceso a tu cámara para fotografiar documentos."
        }
      ]
    ],
    "newArchEnabled": false,
    "experiments": {
      "typedRoutes": true
    }
  }
}